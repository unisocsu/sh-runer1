<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1224"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvCurrentPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Path: /"
        android:textColor="#E0AAFF"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#2D1F3D"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#241933"
        android:padding="6dp">

        <ListView
            android:id="@+id/fileListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#3C2A54"
            android:dividerHeight="1dp"
            android:listSelector="#5A189A" />

        <GridView
            android:id="@+id/fileGridView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="3"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:visibility="gone"
            android:listSelector="#5A189A" />
    </FrameLayout>

    <ScrollView
        android:id="@+id/terminalScrollView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#0D0814"
        android:layout_marginTop="10dp"
        android:padding="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvTerminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnToggleView"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="תצוגת רשת (Grid)"
            android:textColor="#FFFFFF"
            android:background="@android:drawable/btn_default"
            android:layout_marginRight="4dp"/>

        <Button
            android:id="@+id/btnTerminalSettings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="הגדרות צבעים"
            android:textColor="#FFFFFF"
            android:background="@android:drawable/btn_default"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

</LinearLayout>
